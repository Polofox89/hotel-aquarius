# Vorlage – kopieren nach ".env" und anpassen:
#   cp .env.example .env
#
# WICHTIG: Die echte .env NIEMALS committen (steht in .gitignore).

# Deine (Sub-)Domain, die per DNS auf die VPS-IP zeigt.
DOMAIN=chat.hotel-aquarius.de

# E-Mail für Let's Encrypt (Zertifikat-Benachrichtigungen).
ACME_EMAIL=admin@hotel-aquarius.de

# Optional: SMTP für Mailversand (Einladungen, Passwort-Reset).
# Format: smtps://user:pass@smtp.server.de:465
# Leer lassen, wenn (noch) kein Mailversand gebraucht wird.
MAIL_URL=
